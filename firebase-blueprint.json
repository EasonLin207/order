{
  "entities": {
    "Restaurant": {
      "title": "Restaurant",
      "description": "A restaurant offering a menu",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "active"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "An individual dish or drink on a menu",
      "type": "object",
      "properties": {
        "restaurantId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["restaurantId", "name", "price", "active"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer's order for a specific item",
      "type": "object",
      "properties": {
        "restaurantId": { "type": "string" },
        "customerName": { "type": "string" },
        "itemId": { "type": "string" },
        "itemName": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "cooking", "ready", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["restaurantId", "customerName", "itemId", "itemName", "price", "quantity", "status"]
    }
  },
  "firestore": {
    "restaurants": {
      "schema": "Restaurant",
      "description": "Collection of restaurants"
    },
    "menu": {
      "schema": "MenuItem",
      "description": "Consolidated menu items for all restaurants"
    },
    "orders": {
      "schema": "Order",
      "description": "Customer orders"
    }
  }
}
